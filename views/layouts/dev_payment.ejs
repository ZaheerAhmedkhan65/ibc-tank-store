<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Website Restricted</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background:
                radial-gradient(circle at top, #494949 0%, #2b2b2b 30%, #151515 100%);
            font-family: Segoe UI, Tahoma, Geneva, Verdana, sans-serif;
            color: #fff;
        }

        .restricted-box {
            width: min(900px, 95%);
            text-align: center;
            padding: 60px 40px;
            background: rgba(0, 0, 0, .25);
            border: 1px solid rgba(255, 255, 255, .08);
            border-radius: 18px;
            backdrop-filter: blur(10px);
            box-shadow: 0 20px 60px rgba(0, 0, 0, .5);
        }

        .restricted-box h1 {
            font-size: clamp(2rem, 4vw, 4rem);
            font-weight: 700;
            color: #ff7b39;
            line-height: 1.2;
            text-shadow:
                0 0 8px rgba(255, 120, 60, .5),
                0 0 18px rgba(255, 120, 60, .35);
            margin-bottom: 25px;
        }

        .restricted-box p {
            font-size: 1.15rem;
            color: #d8d8d8;
            margin-bottom: 12px;
        }

        .due-date {
            display: inline-block;
            margin: 30px 0;
            padding: 14px 30px;
            border-radius: 50px;
            background: #a10000;
            color: #fff;
            font-size: 1.25rem;
            font-weight: 700;
            box-shadow: 0 0 20px rgba(255, 0, 0, .35);
        }

        .notice {
            color: #cfcfcf;
            font-size: 1rem;
            margin-top: 20px;
            margin-bottom: 35px;
        }

        .btn-contact {
            background: linear-gradient(#ff6f61, #b31818);
            color: #fff;
            border: none;
            padding: 14px 45px;
            border-radius: 10px;
            font-weight: 600;
            transition: .3s;
            box-shadow: 0 10px 25px rgba(255, 70, 70, .35);
        }

        .btn-contact:hover {
            transform: translateY(-3px);
            background: linear-gradient(#ff826d, #ca2020);
        }
    </style>

</head>

<body>

    <div class="restricted-box">

        <h1>
            Website Restricted By Developer<br>
            Due To Incomplete Payments Of Development
        </h1>

        <p>
            This website has been temporarily restricted due to the
            non-payment of development charges.
        </p>

        <div class="due-date">
            Due Date:
            <%= settings.due_date_for_payment || 'Not Specified' %>
        </div>

        <div class="notice">
            If you are the website owner, please contact the developer and
            complete the pending payment before the due date.
            <br>
            Failure to do so may result in permanent suspension of this website.
        </div>

        <a href="https://wa.me/+923080944425?text=<%= encodeURIComponent('Hey! I am ready to pay due payments. Please share due payment details.')%>" class="text-decoration-none" target="_blank"
            rel="noopener noreferrer">
            <button class="btn btn-contact">
             Contact Developer
            </button>
        </a>
        
    </div>

</body>

</html>