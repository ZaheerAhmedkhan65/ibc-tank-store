<!-- Search Results -->
<section class="ibc-page-hero">
  <div class="ibc-container">
    <div class="ibc-breadcrumb">
      <a href="/">Home</a> <i class="bi bi-chevron-right" style="font-size:10px"></i>
      <span>Search Results</span>
    </div>
    <h1>Search Results</h1>
    <% if (products.length > 0) { %>
      <p><%= products.length %> product<%= products.length > 1 ? 's' : '' %> found</p>
    <% } %>
  </div>
</section>

<!-- Quote Form -->
<%- include('./partials/_quote_form.ejs') %>

<section class="ibc-section ibc-bg-white">
  <div class="ibc-container">
    <div style="display:grid;grid-template-columns:1fr;gap:32px">
      <!-- Refine Search -->
      <div class="ibc-filter-card">
        <form action="/search" method="GET" style="display:flex;flex-wrap:wrap;gap:12px;align-items:flex-end">
          <div style="flex:1;min-width:160px">
            <label style="font-size:13px;font-weight:600;color:var(--ibc-gray-700);margin-bottom:4px;display:block">Search</label>
            <input type="text" name="q" value="<%= searchQuery || '' %>" placeholder="Enter keywords..." style="width:100%;padding:10px 14px;border:2px solid var(--ibc-gray-300);border-radius:var(--ibc-radius-sm);font-size:14px">
          </div>
          <div style="flex:1;min-width:150px">
            <label style="font-size:13px;font-weight:600;color:var(--ibc-gray-700);margin-bottom:4px;display:block">Category</label>
            <select name="category" style="width:100%;padding:10px 14px;border:2px solid var(--ibc-gray-300);border-radius:var(--ibc-radius-sm);font-size:14px;background:var(--ibc-white)">
              <option value="">All Categories</option>
              <% (typeof categories !== 'undefined' ? categories : []).forEach(c => { %>
                <option value="<%= c.id %>" <%= selectedCategory == c.id ? 'selected' : '' %>><%= c.name %></option>
              <% }); %>
            </select>
          </div>
          <div style="flex:1;min-width:100px">
            <label style="font-size:13px;font-weight:600;color:var(--ibc-gray-700);margin-bottom:4px;display:block">Min</label>
            <input type="number" name="minPrice" placeholder="Min" value="<%= minPrice || '' %>" style="width:100%;padding:10px 14px;border:2px solid var(--ibc-gray-300);border-radius:var(--ibc-radius-sm);font-size:14px">
          </div>
          <div style="flex:1;min-width:100px">
            <label style="font-size:13px;font-weight:600;color:var(--ibc-gray-700);margin-bottom:4px;display:block">Max</label>
            <input type="number" name="maxPrice" placeholder="Max" value="<%= maxPrice || '' %>" style="width:100%;padding:10px 14px;border:2px solid var(--ibc-gray-300);border-radius:var(--ibc-radius-sm);font-size:14px">
          </div>
          <div style="flex:1;min-width:120px">
            <label style="font-size:13px;font-weight:600;color:var(--ibc-gray-700);margin-bottom:4px;display:block">Condition</label>
            <select name="condition" style="width:100%;padding:10px 14px;border:2px solid var(--ibc-gray-300);border-radius:var(--ibc-radius-sm);font-size:14px;background:var(--ibc-white)">
              <option value="">Any</option>
              <option value="new" <%= condition === 'new' ? 'selected' : '' %>>New</option>
              <option value="used" <%= condition === 'used' ? 'selected' : '' %>>Used</option>
              <option value="refurbished" <%= condition === 'refurbished' ? 'selected' : '' %>>Refurbished</option>
            </select>
          </div>
          <div style="display:flex;gap:8px">
            <button type="submit" class="ibc-btn ibc-btn-primary"><i class="bi bi-search"></i> Search</button>
          </div>
        </form>
      </div>

      <!-- Results -->
      <div>
        <% if (products.length === 0) { %>
          <div style="text-align:center;padding:48px 24px;background:var(--ibc-gray-100);border-radius:var(--ibc-radius-lg)">
            <i class="bi bi-search" style="font-size:48px;color:var(--ibc-gray-500);margin-bottom:16px;display:block"></i>
            <h3 style="font-size:20px;color:var(--ibc-dark);margin-bottom:8px">No Products Found</h3>
            <p style="color:var(--ibc-gray-500)">Try different keywords or browse our product categories.</p>
            <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-top:16px">
              <a href="/water-ibc-tanks" class="ibc-btn ibc-btn-dark ibc-btn-sm">Water Tanks</a>
              <a href="/chemical-ibc-tanks" class="ibc-btn ibc-btn-dark ibc-btn-sm">Chemical Tanks</a>
              <a href="/fertilizer-ibc-tanks" class="ibc-btn ibc-btn-dark ibc-btn-sm">Fertilizer Tanks</a>
              <a href="/food-grade-ibc-tanks" class="ibc-btn ibc-btn-dark ibc-btn-sm">Food Grade Tanks</a>
            </div>
          </div>
        <% } else { %>
          <p style="font-size:14px;color:var(--ibc-gray-500);margin-bottom:16px"><%= products.length %> product<%= products.length > 1 ? 's' : '' %> found</p>
          <div class="ibc-products-grid">
            <% products.forEach(product => { %>
              <a href="/products/<%= product.id %>" class="ibc-product-card ibc-animate" style="text-decoration:none;color:inherit;display:block">
                <div class="ibc-product-img-wrapper">
                  <img src="<%= product.image %>" alt="<%= product.name %>" class="ibc-product-img" loading="lazy" width="400" height="220">
                </div>
                <div class="ibc-product-body">
                  <h3><%= product.name %></h3>
                  <div class="ibc-product-capacity"><i class="bi bi-box"></i> 1000 Liters</div>
                  <p style="font-size:18px;font-weight:700;color:var(--ibc-primary);margin:8px 0"><%= settings.price_currency %><%= product.price %></p>
                  <div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:8px">
                    <a href="https://wa.me/<%= settings.contact_number %>?text=<%= encodeURIComponent('Hi, I am interested in this product: ' + product.name) %>"
                       class="ibc-btn ibc-btn-whatsapp ibc-btn-sm" target="_blank" rel="noopener noreferrer" onclick="event.stopPropagation()">
                      <i class="bi bi-whatsapp"></i> Inquire
                    </a>
                  </div>
                </div>
                <div class="ibc-product-hover-arrow"><i class="bi bi-arrow-right"></i></div>
              </a>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>