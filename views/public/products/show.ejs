<!-- Product Show Page -->
<section class="ibc-page-hero">
  <div class="ibc-container">
    <div class="ibc-breadcrumb">
      <a href="/">Home</a> <i class="bi bi-chevron-right" style="font-size:10px"></i>
      <a href="/products">Products</a> <i class="bi bi-chevron-right" style="font-size:10px"></i>
      <span><%= product.name %></span>
    </div>
    <h1><%= product.name %></h1>
  </div>
</section>

<div class="ibc-section" style="background:var(--ibc-white)">
  <div class="ibc-container">
    <div style="display:grid;grid-template-columns:1fr;gap:40px;align-items:start" class="ibc-animate">
      <!-- Product Images -->
      <div>
        <% if (productImages && productImages.length > 0) { %>
          <div class="ibc-product-gallery">
            <div class="ibc-product-gallery-main">
              <img id="mainProductImage" src="<%= productImages[0] %>" alt="<%= product.name %>" 
                   class="ibc-product-gallery-img" data-index="0" />
              <button class="ibc-gallery-nav ibc-gallery-prev" type="button"><i class="bi bi-chevron-left"></i></button>
              <button class="ibc-gallery-nav ibc-gallery-next" type="button"><i class="bi bi-chevron-right"></i></button>
              <% if (productImages.length > 1) { %>
                <div class="ibc-badge-count"><%= productImages.length %> Photos</div>
              <% } %>
            </div>
            <!-- Thumbnails -->
            <div class="ibc-product-thumbnails">
              <% productImages.forEach((image, index) => { %>
                <div class="ibc-thumb-item <%= index === 0 ? 'active' : '' %>" data-index="<%= index %>">
                  <img src="<%= image %>" alt="Thumbnail <%= index + 1 %>" />
                </div>
              <% }) %>
            </div>
          </div>
        <% } else { %>
          <div class="ibc-product-gallery-main" style="display:flex;align-items:center;justify-content:center;background:var(--ibc-gray-100);min-height:300px;">
            <div style="text-align:center;color:var(--ibc-gray-500);">
              <i class="bi bi-image" style="font-size:48px;margin-bottom:12px;display:block"></i>
              <p>No image available</p>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Product Info -->
      <div>
        <!-- Name (visible on desktop) -->
        <h1 style="font-size:28px;font-weight:800;color:var(--ibc-dark);margin-bottom:12px;display:none"><%= product.name %></h1>

        <!-- Price -->
        <div class="ibc-product-show-price">
          <span class="ibc-price-label">Price</span>
          <span class="ibc-price-value"><%= settings.price_currency %><%= product.price %></span>
        </div>

        <!-- Stock Status -->
        <div style="display:flex;gap:16px;flex-wrap:wrap;margin:16px 0">
          <div class="ibc-info-badge">
            <i class="bi bi-box-seam"></i>
            <span><%= product.stock > 0 ? 'Stock Available' : 'Out of Stock' %></span>
          </div>
          <div class="ibc-info-badge">
            <i class="bi bi-shield-check"></i>
            <span><%= product.product_condition || 'New' %></span>
          </div>
          <div class="ibc-info-badge">
            <i class="bi bi-star-fill" style="color:var(--ibc-accent)"></i>
            <span><%= product.rating %> / 5</span>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="ibc-product-cta-buttons">
          <a href="https://wa.me/<%= settings.contact_number %>?text=<%= encodeURIComponent('Hello, I am interested in your IBC tanks. Please share pricing and availability for: ' + product.name) %>"
             class="ibc-btn ibc-btn-whatsapp ibc-btn-lg" target="_blank" rel="noopener noreferrer">
            <i class="bi bi-whatsapp"></i> WhatsApp Now
          </a>
          <a href="#quote-form-anchor" class="ibc-btn ibc-btn-primary ibc-btn-lg">
            <i class="bi bi-chat-quote"></i> Get Free Quote
          </a>
        </div>

        <!-- Specifications -->
        <% if (product.specs && Object.keys(product.specs).length > 0) { %>
          <div class="ibc-specs-section">
            <h3><i class="bi bi-list-check"></i> Specifications</h3>
            <table class="ibc-spec-table">
              <% Object.entries(product.specs).forEach(([key, value]) => { %>
                <tr>
                  <td><%= key %></td>
                  <td><%= value %></td>
                </tr>
              <% }) %>
            </table>
          </div>
        <% } %>

        <!-- Rating Display -->
        <div class="ibc-rating-display">
          <div class="ibc-rating-stars">
            <% for(let i = 1; i <= 5; i++) { %>
              <% if(i <= Math.floor(product.rating)) { %>
                <i class="bi bi-star-fill"></i>
              <% } else if(i === Math.ceil(product.rating) && product.rating % 1 > 0) { %>
                <i class="bi bi-star-half"></i>
              <% } else { %>
                <i class="bi bi-star"></i>
              <% } %>
            <% } %>
          </div>
          <span><%= product.rating %> / 5 · <%= product.rating_count %> <%= product.rating_count > 1 ? 'Ratings' : 'Rating' %></span>
        </div>

        <!-- Trust Signals -->
        <div class="ibc-trust-signals">
          <div class="ibc-trust-signal">
            <i class="bi bi-truck"></i>
            <span>Nationwide Delivery</span>
          </div>
          <div class="ibc-trust-signal">
            <i class="bi bi-box-seam"></i>
            <span>Bulk Orders Available</span>
          </div>
          <div class="ibc-trust-signal">
            <i class="bi bi-lightning-charge"></i>
            <span>Fast Response</span>
          </div>
          <div class="ibc-trust-signal">
            <i class="bi bi-shield-check"></i>
            <span>Quality Guaranteed</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Tabs -->
    <div class="ibc-product-tabs" style="margin-top:40px">
      <div class="ibc-tab-nav">
        <button class="ibc-tab-btn active" data-tab="description"><i class="bi bi-file-text"></i> Description</button>
        <button class="ibc-tab-btn" data-tab="additional-info"><i class="bi bi-info-circle"></i> Additional Info</button>
        <button class="ibc-tab-btn" data-tab="reviews"><i class="bi bi-chat-dots"></i> Reviews</button>
      </div>

      <div class="ibc-tab-content" id="description" style="display:block">
        <div class="ibc-tab-panel">
          <h3>Description</h3>
          <%- product.description || '<p style="color:var(--ibc-gray-500)">No description available.</p>' %>
        </div>
      </div>

      <div class="ibc-tab-content" id="additional-info" style="display:none">
        <div class="ibc-tab-panel">
          <h3>Additional Information</h3>
          <% if (product.additional_info && Object.keys(product.additional_info).length > 0) { %>
            <table class="ibc-spec-table">
              <% Object.entries(product.additional_info).forEach(([key, value]) => { %>
                <tr>
                  <td><%= key %></td>
                  <td><%= value %></td>
                </tr>
              <% }) %>
            </table>
          <% } else { %>
            <p style="color:var(--ibc-gray-500)">No additional information available.</p>
          <% } %>
        </div>
      </div>

      <div class="ibc-tab-content" id="reviews" style="display:none">
        <div class="ibc-tab-panel">
          <h3>Customer Reviews</h3>
          <% if (ratings.length === 0) { %>
            <p style="color:var(--ibc-gray-500);text-align:center;padding:32px 0">No reviews yet. Be the first to review this product!</p>
          <% } else { %>
            <div class="ibc-reviews-list">
              <% for (let rating of ratings) { %>
                <div class="ibc-review-card">
                  <div class="ibc-review-header">
                    <div class="ibc-testimonial-avatar" style="width:36px;height:36px;font-size:13px">
                      <%= rating.user_name ? rating.user_name.charAt(0).toUpperCase() : 'U' %>
                    </div>
                    <div>
                      <div class="ibc-review-name"><%= rating.user_name %></div>
                      <div class="ibc-review-date"><%= new Date(rating.created_at).toLocaleDateString('en-PK', {year:'numeric',month:'short',day:'numeric'}) %></div>
                    </div>
                  </div>
                  <div class="ibc-review-stars">
                    <% for(let i = 1; i <= 5; i++) { %>
                      <% if(i <= Math.floor(rating.rating)) { %>
                        <i class="bi bi-star-fill"></i>
                      <% } else if(i === Math.ceil(rating.rating) && rating.rating % 1 > 0) { %>
                        <i class="bi bi-star-half"></i>
                      <% } else { %>
                        <i class="bi bi-star"></i>
                      <% } %>
                    <% } %>
                  </div>
                  <% if (rating.comment) { %>
                    <p class="ibc-review-text"><%= rating.comment %></p>
                  <% } %>
                </div>
              <% } %>
            </div>
          <% } %>

          <!-- Rating Form -->
          <div class="ibc-rating-form-section">
            <h4><i class="bi bi-star"></i> Rate this product</h4>
            <form id="ratingForm">
              <div class="ibc-rating-input">
                <% for(let i = 5; i >= 1; i--) { %>
                  <input type="radio" name="rating" value="<%= i %>" id="star<%= i %>">
                  <label for="star<%= i %>"><i class="bi bi-star-fill"></i></label>
                <% } %>
              </div>
              <button type="submit" id="submitRatingBtn" class="ibc-btn ibc-btn-primary ibc-btn-sm" style="display:none">
                <i class="bi bi-check-circle"></i> Submit Rating
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Quote Form Anchor -->
    <div id="quote-form-anchor"></div>

    <!-- WhatsApp & Quote Section -->
    <div class="ibc-product-bottom-cta" style="margin-top:40px">
      <div style="text-align:center;padding:32px;background:linear-gradient(135deg,var(--ibc-primary) 0%,var(--ibc-primary-light) 100%);border-radius:var(--ibc-radius-lg);color:var(--ibc-white)">
        <h3 style="font-size:24px;font-weight:800;margin-bottom:8px">Need Help?</h3>
        <p style="font-size:16px;color:rgba(255,255,255,.8);margin-bottom:24px">Get in touch with our team for pricing, availability, and bulk orders.</p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
          <a href="https://wa.me/<%= settings.contact_number %>?text=<%= encodeURIComponent('Hello, I am interested in your IBC tanks. Please share pricing and availability for: ' + product.name) %>"
             class="ibc-btn ibc-btn-whatsapp ibc-btn-lg" target="_blank" rel="noopener noreferrer">
            <i class="bi bi-whatsapp"></i> WhatsApp Now
          </a>
          <a href="/contact" class="ibc-btn ibc-btn-dark ibc-btn-lg">
            <i class="bi bi-envelope"></i> Contact Us
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Quote Form -->
<%- include('../partials/_quote_form.ejs') %>

<!-- Product Images Data for Fancybox -->
<script type="application/json" id="product-images-data">
<% if(typeof productImages === 'undefined') { %><% }else{ %><%- JSON.stringify(productImages) %><% } %>
</script>
